# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=your_strong_password
DB_NAME=labor_market
DB_HOST=localhost          # у Docker замінюється на 'db' автоматично
DB_PORT=5432

# ─── pgAdmin (веб-інтерфейс до бази) ─────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=your_pgadmin_password

# ─── LLM-каскад (NLP-обробка) ────────────────────────────────────────────────
# Обробник іде по провайдерах послідовно (fallback): коли в одного денний
# безкоштовний бюджет вичерпано — падає на наступного. Активуються лише ті,
# для яких заданий ключ; порядок за замовчуванням: Cerebras → Groq → Gemini → Mistral.
# Сумарна добова продуктивність = сума денних квот усіх увімкнених провайдерів.
#
#   Cerebras  1 млн токенів/добу   — https://cloud.cerebras.ai (без картки)
#   Groq      500K токенів/добу    — https://console.groq.com
#   Gemini    500 запитів/добу     — https://aistudio.google.com/apikey (flash-lite 3.1)
#   Mistral   1 млрд токенів/міс   — https://console.mistral.ai (free «Experiment»)
#
# Достатньо хоча б ОДНОГО ключа. Решту лишай порожніми — провайдер просто не
# увімкнеться. Рекомендований мінімум: Cerebras + Groq.
CEREBRAS_API_KEY=
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY
GEMINI_API_KEY=
MISTRAL_API_KEY=

# Перевизначення моделей (необов'язково — є робочі дефолти):
# CEREBRAS_MODEL=gpt-oss-120b          # альтернатива (preview): zai-glm-4.7
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GEMINI_MODEL=gemini-3.1-flash-lite   # 500 RPD; gemma-4-31b має 1.5K RPD але слабша/JSON?
# MISTRAL_MODEL=mistral-small-latest

# Порядок/склад каскаду (необов'язково), через кому. Напр. лише два провайдери:
# LLM_PROVIDER_ORDER=cerebras,groq

# Розмір порції-вибірки (вакансії + резюме беруть по стільки КОЖЕН за ітерацію).
# Прогін працює в DRAIN-режимі: крутить порції, поки черга не спорожніє або
# денний бюджет усіх провайдерів не вичерпається. Тобто ОДИН cron/добу вже
# вибирає стелю (~1600-2000/добу); цей параметр — лише розмір порції. Типово 200.
# NLP_BATCH_LIMIT=200

# ─── Джерела даних ───────────────────────────────────────────────────────────
# Збираємо лише джерела з повними полями для статистики (ЗП/досвід/англ./гео/
# навички): work.ua (вакансії+резюме), DOU.ua RSS та robota.ua (GraphQL) —
# усі через LLM-обробку. Ключів не потребують.
# robota.ua за Cloudflare: збирач шле браузерні заголовки. Обсяг за прогін —
# ROBOTA_MAX_PAGES (типово 25) × ROBOTA_PAGE_SIZE (типово 40).
# ROBOTA_MAX_PAGES=25

# ─── REST API (CORS для React) ────────────────────────────────────────────────
# Через кому — список дозволених origins. У проді — лише твій домен.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Адмін-панель / JWT (ОБОВ'ЯЗКОВО задати!) ────────────────────────────────
# JWT_SECRET обов'язковий — застосунок НЕ стартує з порожнім або дефолтним
# значенням. Згенерувати: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32

# ADMIN_USERNAME / ADMIN_PASSWORD засівають початковий адмін-акаунт у БД
# (auth.users) на першому старті. Пароль зберігається лише як хеш.
# Усі акаунти — адміністратори; реєстрації через UI немає. Додати акаунт:
#   docker compose exec api python -m scripts.create_user --username NAME
ADMIN_USERNAME=changeme
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Метрики адмінпанелі (необов'язково) ─────────────────────────────────────
# Шлях, по якому рахується зайнятість диска у секції «Сервер» (default '/').
# METRICS_DISK_PATH=/

# ─── Rate limiting (запитів на хвилину з одного IP) ──────────────────────────
# Захист публічних ендпоінтів від спаму/брутфорсу. За проксі (Cloudflare/nginx)
# IP береться з заголовків CF-Connecting-IP / X-Forwarded-For.
# TRACK_RATE_LIMIT=30   # POST /api/track — анонімний beacon відвідувачів
# LOGIN_RATE_LIMIT=10   # POST /api/auth/login — захист від перебору паролів
